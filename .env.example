# Example contents for the GitLab CI/CD variable BIGDIL_ENV.
# Paste the lines below (filled in) into Settings -> CI/CD -> Variables
# as a "File" or masked variable named BIGDIL_ENV. The deploy job writes
# it to /opt/infra/bigdil/.env on the host before running docker compose.

POSTGRES_DB=bigdil
POSTGRES_USER=bigdil
POSTGRES_PASSWORD=change-me
